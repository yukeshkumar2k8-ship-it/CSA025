#include <stdio.h>

int main() {
    float length, breadth, area;

    // Input
    printf("Enter length: ");
    scanf("%f", &length);

    printf("Enter breadth: ");
    scanf("%f", &breadth);

    // Calculate area
    area = length * breadth;

    // Output
    printf("Area of rectangle = %.2f\n", area);

    return 0;
}
