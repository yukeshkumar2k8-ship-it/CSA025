#include <stdio.h>
#include <math.h>
int main(){
    int n,temp,count=0,rem;
    int sum=0;
    scanf("%d",&n);
    temp=n;
    while(temp){
        count++;
        temp/=10;
    }
    temp=n;
    while(temp){
        rem=temp%10;
        sum += pow(rem,count);
        temp/=10;
    }
    if(sum==n) printf("Armstrong");
    else printf("Not Armstrong");
    return 0;
}