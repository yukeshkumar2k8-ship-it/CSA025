#include <stdio.h>
int fact(int n){
    int f=1,i;
    for(i=1;i<=n;i++) f*=i;
    return f;
}
int main(){
    int n,temp,sum=0,rem;
    scanf("%d",&n);
    temp=n;
    while(n!=0){
        rem=n%10;
        sum+=fact(rem);
        n/=10;
    }
    if(sum==temp) printf("Strong Number");
    else printf("Not Strong Number");
    return 0;
}